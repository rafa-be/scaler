// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
    "name": "Scaler-Dev",
    // More info: https://containers.dev/guide/dockerfile
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.black-formatter",
                "ms-python.flake8",
                "ms-python.isort",
                "ms-python.mypy-type-checker",
                "ms-python.python",
                "ms-vscode.cmake-tools",
                "ms-vscode.cpptools"
            ],
            "settings": {
                "[python]": {
                    "editor.defaultFormatter": "ms-python.black-formatter",
                    "editor.formatOnSave": true,
                    "editor.codeActionsOnSave": {
                        "source.organizeImports": "explicit"
                    },
                    "editor.tabSize": 4,
                    "files.trimTrailingWhitespace": true
                },
                "black-formatter.args": ["-l", "120", "-C"],
                "isort.args": ["--profile", "black", "--line-length", "120"],
                "flake8.args": ["--max-line-length", "120", "--extend-ignore", "E203"],
                // Use the venv's flake8 (7.x) rather than the extension's bundled copy:
                // flake8-pyproject 1.2.4 (pulled in via pyproject.toml dev deps) crashes
                // against older bundled flake8 with "AttributeError: 'Namespace' object has
                // no attribute 'toml_config'".
                "flake8.importStrategy": "fromEnvironment",
                "flake8.interpreter": ["${workspaceFolder}/.venv/bin/python"],
                "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
                "cmake.configureOnOpen": false
            }
        }
    }
}
